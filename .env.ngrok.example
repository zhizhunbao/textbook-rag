# Textbook RAG v2.0 - ngrok local deployment template
# Copy to `.env.ngrok` for launch notes, then copy the runtime values you need into `.env`.
# Do not commit `.env.ngrok`.

# Public ngrok URL for Payload / Next.js.
# Example: https://your-subdomain.ngrok-free.app
NGROK_PUBLIC_URL=

# Local services
PAYLOAD_LOCAL_URL=http://localhost:3001
ENGINE_LOCAL_URL=http://localhost:8001

# Runtime values to set in `.env` before launching Payload and Engine.
PAYLOAD_URL=http://localhost:3001
PAYLOAD_PUBLIC_SERVER_URL=
NEXT_PUBLIC_ENGINE_URL=http://localhost:8001
ENGINE_URL=http://localhost:8001
CORS_ORIGINS=http://localhost:3001

# Stripe webhooks for local public callbacks.
# After ngrok starts, configure Stripe webhook endpoint as:
#   <NGROK_PUBLIC_URL>/api/stripe/webhooks
STRIPE_WEBHOOK_PUBLIC_URL=
