  "timestamps": [
    {
      "index": 1,
      "start": 0.15,
      "end": 4.801,
      "text": "AIP，大西洋四省移民，联邦门槛最低的PR通道",
      "slide_index": 0
    },
    {
      "index": 2,
      "start": 5.101,
      "end": 7.978,
      "text": "语言门槛、工作经验都不是问题，",
      "slide_index": 0
    },
    {
      "index": 3,
      "start": 7.978,
      "end": 11.238,
      "text": "关键就一个找到指定雇主的Offer",
      "slide_index": 0
    },
    {
      "index": 4,
      "start": 11.538,
      "end": 16.429,
      "text": "今天讲清楚怎么找雇主、三种人怎么走、流程怎么跑",
      "slide_index": 0
    },
    {
      "index": 5,
      "start": 17.229,
      "end": 20.212,
      "text": "AIP有三条路，难度差别非常大",
      "slide_index": 1
    },
    {
      "index": 6,
      "start": 20.512,
      "end": 21.909,
      "text": "上学的最简单，",
      "slide_index": 1
    },
    {
      "index": 7,
      "start": 21.909,
      "end": 23.904,
      "text": "四省2年制以上毕业，",
      "slide_index": 1
    },
    {
      "index": 8,
      "start": 23.904,
      "end": 25.501,
      "text": "工作经验直接免，",
      "slide_index": 1
    },
    {
      "index": 9,
      "start": 25.501,
      "end": 28.893,
      "text": "一毕业拿到指定雇主Offer就能递",
      "slide_index": 1
    },
    {
      "index": 10,
      "start": 29.193,
      "end": 30.279,
      "text": "持工签的，",
      "slide_index": 1
    },
    {
      "index": 11,
      "start": 30.279,
      "end": 32.668,
      "text": "比如毕业工签PGWP，",
      "slide_index": 1
    },
    {
      "index": 12,
      "start": 32.668,
      "end": 35.057,
      "text": "需要先给雇主干满1年，",
      "slide_index": 1
    },
    {
      "index": 13,
      "start": 35.057,
      "end": 37.012,
      "text": "5年内的经验都算，",
      "slide_index": 1
    },
    {
      "index": 14,
      "start": 37.012,
      "end": 38.749,
      "text": "任何合法工签都行",
      "slide_index": 1
    },
    {
      "index": 15,
      "start": 39.049,
      "end": 39.959,
      "text": "海外直申，",
      "slide_index": 1
    },
    {
      "index": 16,
      "start": 39.959,
      "end": 41.598,
      "text": "人在境外也能申请，",
      "slide_index": 1
    },
    {
      "index": 17,
      "start": 41.598,
      "end": 44.693,
      "text": "但前提一样拿到指定雇主的Offer",
      "slide_index": 1
    },
    {
      "index": 18,
      "start": 44.993,
      "end": 48.746,
      "text": "没有Offer什么都白搭，这是AIP的游戏规则",
      "slide_index": 1
    },
    {
      "index": 19,
      "start": 49.546,
      "end": 54.119,
      "text": "TEER 0到3，管理岗和技术岗，语言要CLB 5",
      "slide_index": 2
    },
    {
      "index": 20,
      "start": 54.419,
      "end": 56.944,
      "text": "CLB就是加拿大语言等级",
      "slide_index": 2
    },
    {
      "index": 21,
      "start": 57.244,
      "end": 60.281,
      "text": "TEER 4服务岗只要CLB 4，",
      "slide_index": 2
    },
    {
      "index": 22,
      "start": 60.281,
      "end": 62.067,
      "text": "基础日常交流水平就够",
      "slide_index": 2
    },
    {
      "index": 23,
      "start": 62.367,
      "end": 65.42,
      "text": "对比联邦快速通道要CLB 7，",
      "slide_index": 2
    },
    {
      "index": 24,
      "start": 65.42,
      "end": 67.66,
      "text": "AIP低了两三个等级，",
      "slide_index": 2
    },
    {
      "index": 25,
      "start": 67.66,
      "end": 70.306,
      "text": "几乎是移民项目里门槛最低的",
      "slide_index": 2
    },
    {
      "index": 26,
      "start": 71.106,
      "end": 73.878,
      "text": "英语三个考试都认CELPIP考General版，",
      "slide_index": 3
    },
    {
      "index": 27,
      "start": 73.878,
      "end": 76.534,
      "text": "IELTS考General Training版",
      "slide_index": 3
    },
    {
      "index": 28,
      "start": 76.834,
      "end": 78.363,
      "text": "PTE考Core版，",
      "slide_index": 3
    },
    {
      "index": 29,
      "start": 78.363,
      "end": 82.033,
      "text": "法语认TEF Canada和TCF Canada",
      "slide_index": 3
    },
    {
      "index": 30,
      "start": 82.333,
      "end": 86.12,
      "text": "成绩有效期2年，递申请的时候不能过期",
      "slide_index": 3
    },
    {
      "index": 31,
      "start": 86.92,
      "end": 91.392,
      "text": "指定雇主，就是省政府认证的、可以帮你走AIP的公司",
      "slide_index": 4
    },
    {
      "index": 32,
      "start": 91.692,
      "end": 93.898,
      "text": "屏幕上是四省查询入口，",
      "slide_index": 4
    },
    {
      "index": 33,
      "start": 93.898,
      "end": 96.705,
      "text": "每个省都公开了指定雇主名单，",
      "slide_index": 4
    },
    {
      "index": 34,
      "start": 96.705,
      "end": 97.708,
      "text": "直接搜就行",
      "slide_index": 4
    },
    {
      "index": 35,
      "start": 98.008,
      "end": 100.608,
      "text": "上了名单不等于正在招人，",
      "slide_index": 4
    },
    {
      "index": 36,
      "start": 100.608,
      "end": 103.859,
      "text": "你要自己查名单、投简历、面试，",
      "slide_index": 4
    },
    {
      "index": 37,
      "start": 103.859,
      "end": 105.376,
      "text": "跟正常求职一样",
      "slide_index": 4
    },
    {
      "index": 38,
      "start": 106.176,
      "end": 109.204,
      "text": "拿到Offer还得满足4个硬性条件",
      "slide_index": 5
    },
    {
      "index": 39,
      "start": 109.504,
      "end": 112.304,
      "text": "全职，每周至少30小时带薪",
      "slide_index": 5
    },
    {
      "index": 40,
      "start": 112.604,
      "end": 115.359,
      "text": "非季节性，全年有稳定排班",
      "slide_index": 5
    },
    {
      "index": 41,
      "start": 115.659,
      "end": 118.7,
      "text": "TEER 0到3的岗位至少1年合同，",
      "slide_index": 5
    },
    {
      "index": 42,
      "start": 118.7,
      "end": 120.897,
      "text": "TEER 4必须是永久岗位",
      "slide_index": 5
    },
    {
      "index": 43,
      "start": 121.197,
      "end": 123.87,
      "text": "还有一条不能是自己的公司，",
      "slide_index": 5
    },
    {
      "index": 44,
      "start": 123.87,
      "end": 126.749,
      "text": "申请人和配偶不能是公司大股东",
      "slide_index": 5
    },
    {
      "index": 45,
      "start": 127.549,
      "end": 131.046,
      "text": "拿到Offer之后的流程很清楚，5步走完",
      "slide_index": 6
    },
    {
      "index": 46,
      "start": 131.346,
      "end": 134.038,
      "text": "第一步，指定雇主给你Offer",
      "slide_index": 6
    },
    {
      "index": 47,
      "start": 134.338,
      "end": 134.889,
      "text": "第二步，",
      "slide_index": 6
    },
    {
      "index": 48,
      "start": 134.889,
      "end": 136.129,
      "text": "联系安置服务机构，",
      "slide_index": 6
    },
    {
      "index": 49,
      "start": 136.129,
      "end": 138.608,
      "text": "做一份Settlement Plan",
      "slide_index": 6
    },
    {
      "index": 50,
      "start": 138.908,
      "end": 139.594,
      "text": "第三步，",
      "slide_index": 6
    },
    {
      "index": 51,
      "start": 139.594,
      "end": 141.309,
      "text": "把安置计划交给雇主，",
      "slide_index": 6
    },
    {
      "index": 52,
      "start": 141.309,
      "end": 144.91,
      "text": "雇主向省政府提交endorsement申请",
      "slide_index": 6
    },
    {
      "index": 53,
      "start": 145.21,
      "end": 148.237,
      "text": "第四步，你拿到省政府的背书证书",
      "slide_index": 6
    },
    {
      "index": 54,
      "start": 148.537,
      "end": 152.272,
      "text": "第五步，拿着背书证书递联邦PR申请",
      "slide_index": 6
    },
    {
      "index": 55,
      "start": 152.572,
      "end": 155.898,
      "text": "等批的过程中可以申请工签先去上班",
      "slide_index": 6
    },
    {
      "index": 56,
      "start": 156.698,
      "end": 157.722,
      "text": "处理时间，",
      "slide_index": 7
    },
    {
      "index": 57,
      "start": 157.722,
      "end": 159.771,
      "text": "官网显示约40个月，",
      "slide_index": 7
    },
    {
      "index": 58,
      "start": 159.771,
      "end": 161.82,
      "text": "费用1590加币起，",
      "slide_index": 7
    },
    {
      "index": 59,
      "start": 161.82,
      "end": 164.074,
      "text": "2026年4月底刚涨的",
      "slide_index": 7
    },
    {
      "index": 60,
      "start": 164.374,
      "end": 167.536,
      "text": "资金证明单人最低3815加币，",
      "slide_index": 7
    },
    {
      "index": 61,
      "start": 167.536,
      "end": 170.487,
      "text": "但已经持工签在加拿大工作的，",
      "slide_index": 7
    },
    {
      "index": 62,
      "start": 170.487,
      "end": 171.541,
      "text": "不需要提供",
      "slide_index": 7
    },
    {
      "index": 63,
      "start": 172.341,
      "end": 176.725,
      "text": "所有数据来自IRCC官网和四省移民局官网，",
      "slide_index": 8
    },
    {
      "index": 64,
      "start": 176.725,
      "end": 178.604,
      "text": "截止2026年6月",
      "slide_index": 8
    },
    {
      "index": 65,
      "start": 178.904,
      "end": 183.005,
      "text": "四省的AIP入口和求职资源链接都在屏幕上，",
      "slide_index": 8
    },
    {
      "index": 66,
      "start": 183.005,
      "end": 183.981,
      "text": "可以直接查",
      "slide_index": 8
    },
    {
      "index": 67,
      "start": 184.781,
      "end": 187.475,
      "text": "有什么想了解的，评论区留下来",
      "slide_index": 9
    },
    {
      "index": 68,
      "start": 187.775,
      "end": 191.336,
      "text": "下期开始逐省拆解AIP指定雇主，",
      "slide_index": 9
    },
    {
      "index": 69,
      "start": 191.336,
      "end": 193.784,
      "text": "先从NS新斯科舍省讲起",
      "slide_index": 9
    },
    {
      "index": 70,
      "start": 194.084,
      "end": 195.575,
      "text": "关注我，下期见",
      "slide_index": 9
    }
  ],
