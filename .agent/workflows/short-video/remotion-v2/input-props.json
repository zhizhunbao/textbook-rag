  "timestamps": [
    {
      "index": 1,
      "start": 0.15,
      "end": 3.775,
      "text": "2026年联邦拿PR，还剩10条通道",
      "slide_index": 0
    },
    {
      "index": 2,
      "start": 4.075,
      "end": 6.315,
      "text": "哪条还能走，快速过一遍",
      "slide_index": 0
    },
    {
      "index": 3,
      "start": 7.115,
      "end": 8.568,
      "text": "EE快速通道，",
      "slide_index": 1
    },
    {
      "index": 4,
      "start": 8.568,
      "end": 9.606,
      "text": "联邦主力，",
      "slide_index": 1
    },
    {
      "index": 5,
      "start": 9.606,
      "end": 11.474,
      "text": "学历语言年龄打分，",
      "slide_index": 1
    },
    {
      "index": 6,
      "start": 11.474,
      "end": 12.719,
      "text": "够线直接邀请",
      "slide_index": 1
    },
    {
      "index": 7,
      "start": 13.019,
      "end": 15.101,
      "text": "医生专属通道单独开，",
      "slide_index": 1
    },
    {
      "index": 8,
      "start": 15.101,
      "end": 16.766,
      "text": "护理工试点已关，",
      "slide_index": 1
    },
    {
      "index": 9,
      "start": 16.766,
      "end": 18.431,
      "text": "目前只能申请工签",
      "slide_index": 1
    },
    {
      "index": 10,
      "start": 18.731,
      "end": 22.689,
      "text": "PNP省提名，各省自己定规则，名额最多",
      "slide_index": 1
    },
    {
      "index": 11,
      "start": 22.989,
      "end": 28.165,
      "text": "AIP大西洋四省，语言只要CLB 4，联邦门槛最低",
      "slide_index": 1
    },
    {
      "index": 12,
      "start": 28.465,
      "end": 30.8,
      "text": "RCIP农村社区试点，",
      "slide_index": 1
    },
    {
      "index": 13,
      "start": 30.8,
      "end": 33.984,
      "text": "2024年12月刚启动，新通道",
      "slide_index": 1
    },
    {
      "index": 14,
      "start": 34.284,
      "end": 37.249,
      "text": "魁省走独立体系，不进EE池子",
      "slide_index": 1
    },
    {
      "index": 15,
      "start": 37.549,
      "end": 42.088,
      "text": "家庭团聚靠担保，难民走人道，跟技术条件无关",
      "slide_index": 1
    },
    {
      "index": 16,
      "start": 42.388,
      "end": 47.136,
      "text": "港人通道2026年8月31号到期，还剩3个月窗口",
      "slide_index": 1
    },
    {
      "index": 17,
      "start": 47.936,
      "end": 50.843,
      "text": "SUV创业签证和自雇SEP，",
      "slide_index": 2
    },
    {
      "index": 18,
      "start": 50.843,
      "end": 53.75,
      "text": "2026年1月1号起暂停受理",
      "slide_index": 2
    },
    {
      "index": 19,
      "start": 54.05,
      "end": 57.113,
      "text": "以前想走这两条的，现在必须换路",
      "slide_index": 2
    },
    {
      "index": 20,
      "start": 57.413,
      "end": 62.658,
      "text": "TR转PR、农食试点、GTA建筑工这些，早都过期了",
      "slide_index": 2
    },
    {
      "index": 21,
      "start": 63.458,
      "end": 66.1,
      "text": "所有数据来自IRCC官网",
      "slide_index": 3
    },
    {
      "index": 22,
      "start": 66.9,
      "end": 70.742,
      "text": "下期讲AIP大西洋四省，联邦门槛最低",
      "slide_index": 4
    },
    {
      "index": 23,
      "start": 71.042,
      "end": 72.533,
      "text": "关注我，下期见",
      "slide_index": 4
    }
  ],
