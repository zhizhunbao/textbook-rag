# Local environment reference for the React + FastAPI textbook RAG app.
# Copy to `.env` and adjust values as needed.

# ── Frontend ──
VITE_API_ORIGIN=http://127.0.0.1:8000

# ── Backend ──
DATABASE_PATH=data/textbook_rag.sqlite3
CHROMA_PERSIST_DIR=data/chroma_persist
TEXTBOOKS_DIR=textbooks
DATA_DIR=data
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=all-MiniLM-L6-v2
CORS_ORIGINS=http://localhost:3000

# Optional bootstrap cap for faster local startup when validating a subset of books.
TEXTBOOK_RAG_BOOTSTRAP_LIMIT_BOOKS=
