# Textbook RAG v2.0 — 本地环境变量参考
# 复制到 `.env` 并填写实际值

# ── 数据路径 ──────────────────────────────────────────────────
DATA_DIR=data
DATABASE_PATH=data/textbook_rag.sqlite3
CHROMA_PERSIST_DIR=data/chroma_persist
TEXTBOOKS_DIR=data/raw_pdfs/textbooks
MINERU_OUTPUT_DIR=data/mineru_output

# ── Ollama (本地 LLM) ────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Engine API ───────────────────────────────────────────────
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Payload CMS ──────────────────────────────────────────────
PAYLOAD_SECRET=change-me-to-a-random-32-char-string
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/textbook_rag
PAYLOAD_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
ENGINE_URL=http://127.0.0.1:8001

# ── Azure OpenAI (可选，不填则使用 Ollama) ───────────────────
AZURE_OAI_ENDPOINT=
AZURE_OAI_KEY=
AZURE_OAI_DEPLOYMENT=gpt-4o
AZURE_OAI_API_VERSION=2024-08-01-preview

# ── Azure AI Search (可选) ───────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=
