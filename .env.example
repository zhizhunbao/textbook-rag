# Local runtime reference for the CST8507 assignment setup.
# Copy to `.env` only if you want a private local note file.
# The current application reads most runtime settings from `backend/config.yaml`;
# these values document the expected environment for local execution.

# Ollama service
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# UI launcher choice: streamlit | gradio | nicegui
UI_VARIANT=streamlit

# Optional ROS 2 handoff values for Part 2
ROS2_MODEL=qwen2.5:0.5b
ROS2_RAG_PATH=/home/aisd/aisd_ali/knowledge/ragfile.txt
